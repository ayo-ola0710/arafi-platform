# Arafi Demo Store - Environment Variables Configuration Template
# Copy this file to '.env.local' and update values for local testing.

# The base URL of the Arafi Backend API (e.g. http://localhost:10000 or production Render URL)
NEXT_PUBLIC_ARAFI_API_URL=https://arafi-api.onrender.com

# The workspace publishable API key generated in the Arafi Dashboard (starts with arafi_test_ or arafi_live_)
NEXT_PUBLIC_ARAFI_PUBLISHABLE_KEY=arafi_test_your_key_here
